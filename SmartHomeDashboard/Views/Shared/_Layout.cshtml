<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartHomeDashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">SmartHomeDashboard</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main role="main" class="pb-3 container">
        @RenderBody()
    </main>

    <footer class="border-top text-muted text-center mt-4 py-3">
        <div class="container">
            &copy; @DateTime.Now.Year - SmartHomeDashboard
        </div>
    </footer>
</body>
</html>
